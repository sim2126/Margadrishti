# Copy to .env. Never commit real secrets. Model IDs are env vars by policy (CLAUDE.md).

# --- Claude copilot ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_REASONING=claude-opus-4-8     # optional heavy one-off briefings
CLAUDE_MODEL_FAST=claude-sonnet-4-6        # live copilot: cost-sensitive / high-volume
CLAUDE_MODEL_PRICES_MTOK=claude-haiku-4-5:1,5;claude-sonnet-4-6:3,15;claude-opus-4-8:15,75

# --- Serving DB (PostGIS) + broker (Redis) ---
# Generate real secrets before production. docker compose also reads these names from
# the root .env/environment; no service should boot with default/demo credentials.
POSTGIS_PASSWORD=replace-with-long-random-postgis-password
MARGA_API_PASSWORD=replace-with-long-random-api-reader-password
REDIS_PASSWORD=replace-with-long-random-redis-password

# Writer/owner DSN (worker/publish bypasses RLS to load tables).
POSTGIS_DSN=postgresql://margadrishti:replace-with-long-random-postgis-password@localhost:5432/margadrishti
# Reader DSN — non-owner login role so zone-scoped RLS binds for the API. Rotate the
# password in real deployments. Required when MARGA_OFFLINE=false.
POSTGIS_READ_DSN=postgresql://margadrishti_api:replace-with-long-random-api-reader-password@localhost:5432/margadrishti
REDIS_URL=redis://:replace-with-long-random-redis-password@localhost:6379/0

# Browser origins allowed to call the API. Set this to the deployed frontend origin in
# production, e.g. https://margadrishti.pages.dev. Use "*" only for local/demo testing.
MARGA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage roots (medallion artifacts) ---
MARGA_DATA_ROOT=./data                    # bronze/ silver/ gold/ live here
MARGA_RESTRICTED_ROOT=./data/_restricted  # PII-only store (access-controlled)

# --- Raw inputs ---
RAW_VIOLATIONS_CSV=../jan to may police violation_anonymized791b166.csv
RAW_EVENTS_CSV=../Astram event data_anonymized - Astram event data_anonymizedb40ac87.csv

# --- Geo / time ---
MARGA_BBOX=Bengaluru, Karnataka, India
MARGA_TZ=Asia/Kolkata
H3_RESOLUTION=10                           # aggregation/render only; not the model unit

# --- Modes ---
# false → production serving from PostGIS (docker compose). true → reproducibility/CI
# tier: DuckDB/Parquet only, no PostGIS/Redis/network required.
MARGA_OFFLINE=true
MARGA_SEED=42
MARGA_PII_SALT=replace-with-long-random-pseudonymisation-salt

# Copy to .env. Never commit real secrets. Model IDs are env vars by policy (CLAUDE.md).

# --- Claude copilot ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_REASONING=claude-opus-4-8     # reasoning-heavy briefings
CLAUDE_MODEL_FAST=claude-sonnet-4-6        # cost-sensitive / high-volume

# --- Serving DB (PostGIS) + broker (Redis) ---
# Writer/owner DSN (worker/publish bypasses RLS to load tables).
POSTGIS_DSN=postgresql://parkiq:parkiq@localhost:5432/parkiq
# Reader DSN — non-owner login role so zone-scoped RLS binds for the API. Rotate the
# password in real deployments. Falls back to POSTGIS_DSN if unset (RLS then bypassed).
POSTGIS_READ_DSN=postgresql://parkiq_api:parkiq_api@localhost:5432/parkiq
REDIS_URL=redis://localhost:6379/0

# --- Storage roots (medallion artifacts) ---
PARKIQ_DATA_ROOT=./data                    # bronze/ silver/ gold/ live here
PARKIQ_RESTRICTED_ROOT=./data/_restricted  # PII-only store (access-controlled)

# --- Raw inputs ---
RAW_VIOLATIONS_CSV=../jan to may police violation_anonymized791b166.csv
RAW_EVENTS_CSV=../Astram event data_anonymized - Astram event data_anonymizedb40ac87.csv

# --- Geo / time ---
PARKIQ_BBOX=Bengaluru, Karnataka, India
PARKIQ_TZ=Asia/Kolkata
H3_RESOLUTION=10                           # aggregation/render only; not the model unit

# --- Modes ---
# false → production serving from PostGIS (docker compose). true → reproducibility/CI
# tier: DuckDB/Parquet only, no PostGIS/Redis/network required.
PARKIQ_OFFLINE=true
PARKIQ_SEED=42

# Margadrishti docker-compose environment.
# Copy to .env at the repository root before running docker compose.
# Never commit the real .env.

POSTGIS_PASSWORD=replace-with-long-random-postgis-password
MARGA_API_PASSWORD=replace-with-long-random-api-reader-password
REDIS_PASSWORD=replace-with-long-random-redis-password
MARGA_PII_SALT=replace-with-long-random-pseudonymisation-salt

# Deployed frontend origin(s), comma-separated. For local frontend:
MARGA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: blank-but-set runs the full data extent; unset defaults to bounded bootstrap.
# MARGA_ETL_BBOX=

# Optional: enable only behind auth/rate limiting.
# ANTHROPIC_API_KEY=sk-ant-...
# MARGA_COPILOT_LLM_ENABLED=false
# CLAUDE_MODEL_FAST=claude-sonnet-4-6
# CLAUDE_MODEL_PRICES_MTOK=claude-haiku-4-5:1,5;claude-sonnet-4-6:3,15;claude-opus-4-8:15,75
